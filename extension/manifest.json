{
  "manifest_version": 3,
  "name": "Wallgarden",
  "version": "1.1.0",
  "description": "Filters out YouTube Brainrot, Shorts, clickbait, and spam using CSS rules and heuristics.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "scripts/content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://10.0.0.16/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "scripts/wallgarden-bridge.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
