# Wallgarden Sync Service config.
# In production these are supplied by the deploy-staged env (deploy-kit/.env.deploy).
# For local runs, copy to .env and fill in.

# Mongo connection (same NAS instance the rest of the ecosystem uses)
MONGO_URI=mongodb://<MONGO_USER>:<MONGO_PASS>@10.0.0.16:27017/?directConnection=true&authSource=admin

# Dedicated database — keeps Wallgarden data isolated from everything else
WALLGARDEN_MONGO_DB=wallgarden
